<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>每日 P&L 日報</title>
<style>
:root{
  --bg:#060a14;--s1:#0c1524;--s2:#111e35;--s3:#162540;
  --border:#1a2d4a;--border2:#243d60;
  --accent:#00d4ff;--purple:#7c3aed;--green:#10b981;
  --red:#ef4444;--yellow:#f59e0b;--text:#e2e8f0;--muted:#5a7a9e;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:'SF Pro Display',-apple-system,sans-serif;min-height:100vh}
header{
  background:var(--s1);border-bottom:1px solid var(--border);
  padding:13px 24px;display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:50
}
.h-title{font-size:15px;font-weight:700}.h-sub{font-size:11px;color:var(--muted);margin-top:1px}
#gen-btn{padding:7px 18px;background:var(--green);color:#fff;border:none;border-radius:7px;cursor:pointer;font-size:12px;font-weight:700;transition:opacity .2s}
#gen-btn:hover{opacity:.85}#gen-btn:disabled{opacity:.4;cursor:not-allowed}
.wrap{padding:20px 24px;max-width:1200px;margin:0 auto}
/* date header */
.date-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.date-main{font-size:26px;font-weight:700}
.date-sub{font-size:13px;color:var(--muted);margin-top:2px}
.market-pills{display:flex;gap:8px;flex-wrap:wrap}
.mpill{background:var(--s2);border:1px solid var(--border);border-radius:6px;padding:5px 11px;font-size:11px;display:flex;align-items:center;gap:5px}
/* summary row */
.sum-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:20px}
.sum-card{background:var(--s1);border:1px solid var(--border);border-radius:9px;padding:13px}
.sc-label{font-size:9px;font-weight:700;letter-spacing:1.2px;color:var(--muted);text-transform:uppercase;margin-bottom:6px}
.sc-val{font-size:20px;font-weight:700;font-variant-numeric:tabular-nums;line-height:1}
.sc-sub{font-size:10px;color:var(--muted);margin-top:3px}
.green{color:var(--green)}.red{color:var(--red)}.yellow{color:var(--yellow)}.cyan{color:var(--accent)}
/* section */
.sep{font-size:9px;font-weight:700;letter-spacing:1.4px;color:#3a5270;text-transform:uppercase;margin:16px 0 10px;display:flex;align-items:center;gap:6px}
.sep::after{content:'';flex:1;height:1px;background:var(--border)}
.card{background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:14px}
/* pos table */
.pt{width:100%;border-collapse:collapse;font-size:12px}
.pt th{font-size:9px;font-weight:700;letter-spacing:.8px;color:var(--muted);text-transform:uppercase;padding:6px 8px;border-bottom:1px solid var(--border);text-align:left}
.pt td{padding:8px 8px;border-bottom:1px solid rgba(26,45,74,.4);vertical-align:middle}
.pt tr:last-child td{border-bottom:none}
.pt tbody tr:hover td{background:var(--s2)}
.badge{display:inline-block;padding:2px 6px;border-radius:4px;font-size:9px;font-weight:600}
.b-cc{background:rgba(124,58,237,.2);color:#c4b5fd}
.b-csp{background:rgba(16,185,129,.15);color:#6ee7b7}
.b-bps{background:rgba(0,212,255,.1);color:var(--accent)}
.b-box{background:rgba(245,158,11,.1);color:var(--yellow)}
/* action items */
.action-list{display:flex;flex-direction:column;gap:6px}
.action-item{
  display:flex;align-items:flex-start;gap:10px;
  background:var(--s2);border:1px solid var(--border);border-radius:8px;padding:10px 13px
}
.ai-icon{font-size:16px;flex-shrink:0;margin-top:1px}
.ai-text{flex:1;font-size:12px;line-height:1.5}
.ai-prio{font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;flex-shrink:0}
.prio-1{background:rgba(239,68,68,.2);color:#fca5a5}
.prio-2{background:rgba(245,158,11,.15);color:#fcd34d}
.prio-3{background:rgba(16,185,129,.1);color:#6ee7b7}
/* theta tracker */
.theta-row{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(26,45,74,.3)}
.theta-row:last-child{border-bottom:none}
/* monthly progress */
.progress-bar{height:10px;border-radius:5px;background:var(--border);overflow:hidden;margin:6px 0 2px}
.progress-fill{height:100%;border-radius:5px;transition:width .6s}
/* grid layouts */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
/* ani briefing */
.briefing-box{
  background:linear-gradient(135deg,rgba(124,58,237,.08),rgba(0,212,255,.04));
  border:1px solid rgba(124,58,237,.3);border-radius:10px;padding:16px;
  font-size:13px;line-height:1.7;color:var(--text)
}
.briefing-title{font-size:11px;font-weight:700;color:#c4b5fd;text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;display:flex;align-items:center;gap:6px}
.loading{display:flex;gap:4px;align-items:center}
.loading span{width:6px;height:6px;border-radius:50%;background:var(--muted);animation:bop 1.2s infinite}
.loading span:nth-child(2){animation-delay:.2s}.loading span:nth-child(3){animation-delay:.4s}
@keyframes bop{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-5px)}}
/* skeleton */
.sk{background:linear-gradient(90deg,var(--border) 25%,var(--s2) 50%,var(--border) 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:4px;height:20px}
@keyframes shimmer{0%{background-position:200%}100%{background-position:-200%}}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
@media(max-width:900px){.sum-grid{grid-template-columns:1fr 1fr}.grid2,.grid3{grid-template-columns:1fr}}
</style>
</head>
<body>

<header>
  <div>
    <div class="h-title">📋 每日 P&L 日報</div>
    <div class="h-sub">開盤前晨報 · 自動從 IB 拉取 · Ani 分析</div>
  </div>
  <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
    <span id="sync-badge" style="font-size:11px;color:var(--muted)">⏳ 等待同步…</span>
    <span id="last-gen" style="font-size:11px;color:var(--muted)">尚未生成</span>
    <button id="gen-btn" onclick="generateReport()">🔄 生成今日日報</button>
  </div>
</header>

<div class="wrap">

  <!-- DATE + MARKET -->
  <div class="date-bar">
    <div>
      <div class="date-main" id="report-date">2026年6月11日（四）</div>
      <div class="date-sub" id="report-week">本月第 11 個交易日 · 距月底 20 天</div>
    </div>
    <div class="market-pills" id="market-pills">
      <div class="mpill"><span>📈</span><span>S&P500</span><span class="red">-1.62%</span></div>
      <div class="mpill"><span>💻</span><span>NASDAQ</span><span class="red">-1.98%</span></div>
      <div class="mpill"><span>😱</span><span>VIX</span><span class="red">22.22 (+11.8%)</span></div>
      <div class="mpill"><span>💱</span><span>USD/TWD</span><span>31.68</span></div>
    </div>
  </div>

  <!-- SUMMARY STRIP -->
  <div class="sum-grid">
    <div class="sum-card">
      <div class="sc-label">💰 NLV</div>
      <div class="sc-val cyan" id="r-nlv">$251,749</div>
      <div class="sc-sub" id="r-nlv-sub">≈ NT$797萬</div>
    </div>
    <div class="sum-card">
      <div class="sc-label">📊 未實現 P&L</div>
      <div class="sc-val green" id="r-unrealized">+$2,018</div>
      <div class="sc-sub" id="r-unrealized-sub">≈ NT$63,929</div>
    </div>
    <div class="sum-card">
      <div class="sc-label">⏱️ 今日 Theta</div>
      <div class="sc-val green" id="r-theta">+$175</div>
      <div class="sc-sub">≈ NT$5,547</div>
    </div>
    <div class="sum-card">
      <div class="sc-label">🛡️ Excess Liq.</div>
      <div class="sc-val" id="r-el">$107,835</div>
      <div class="sc-sub" id="r-el-sub">42.8% · ✅ 健康</div>
    </div>
    <div class="sum-card">
      <div class="sc-label">📅 Box 倒數</div>
      <div class="sc-val yellow">189天</div>
      <div class="sc-sub">2026/12/17 到期</div>
    </div>
  </div>

  <div class="grid2">

    <!-- LEFT COL -->
    <div>
      <!-- ACTION ITEMS -->
      <div class="sep">🔴 今日待辦事項</div>
      <div class="action-list" id="action-list">
        <div class="action-item">
          <span class="ai-icon">🔴</span>
          <div class="ai-text"><strong>NVDA CSP $215</strong>：Delta 0.605 超過 0.50 警戒值，標的 $202.35 已接近 Strike，需評估 Roll Down</div>
          <span class="ai-prio prio-1">P1 立即</span>
        </div>
        <div class="action-item">
          <span class="ai-icon">⚠️</span>
          <div class="ai-text"><strong>TSLA CC $460</strong>：獲利 52.8% 達 50% 觸發點，可考慮提前平倉進入新週期（IVR 34，尚可）</div>
          <span class="ai-prio prio-2">P2 本週</span>
        </div>
        <div class="action-item">
          <span class="ai-icon">⚠️</span>
          <div class="ai-text"><strong>VTI CC $370</strong>：獲利 50.9% 達觸發點，標的 $359.92，OTM 2.8%，安全距離偏窄</div>
          <span class="ai-prio prio-2">P2 本週</span>
        </div>
        <div class="action-item">
          <span class="ai-icon">⚠️</span>
          <div class="ai-text"><strong>QQQ BPS $680</strong>：虧損 54.6%，標的 $696.87 已高於 Short Strike $680，需監控</div>
          <span class="ai-prio prio-2">P2 監控</span>
        </div>
        <div class="action-item">
          <span class="ai-icon">📦</span>
          <div class="ai-text"><strong>Box Spread</strong>：189天後到期，2026/10月前評估展延，目標利率 &lt;4.3%</div>
          <span class="ai-prio prio-3">P3 規劃</span>
        </div>
      </div>

      <!-- MONTHLY THETA PROGRESS -->
      <div class="sep">📈 本月 Theta 收益進度</div>
      <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:4px">
          <span style="font-size:12px;color:var(--muted)">目標：NT$100,000 / 月</span>
          <span style="font-size:16px;font-weight:700;color:var(--yellow)">23.7%</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill" style="width:23.7%;background:var(--yellow)"></div>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:10px;color:var(--muted);margin-bottom:12px">
          <span>NT$23,739 已收</span><span>NT$76,261 待收</span>
        </div>

        <div id="monthly-breakdown">
          <div class="theta-row">
            <span style="font-size:12px;font-weight:600">已實現權利金（本月）</span>
            <span style="font-size:13px;font-weight:700;color:var(--green)">NT$23,739</span>
          </div>
          <div class="theta-row">
            <span style="font-size:12px">每日 Theta 累積（持倉中）</span>
            <span style="font-size:13px;font-weight:700;color:var(--green)">NT$5,547/日</span>
          </div>
          <div class="theta-row">
            <span style="font-size:12px">距月底剩餘天數</span>
            <span style="font-size:13px;font-weight:700">20天</span>
          </div>
          <div class="theta-row" style="border-top:1px solid var(--border2);margin-top:4px;padding-top:8px">
            <span style="font-size:12px;font-weight:600">月底預估（若倉位不變）</span>
            <span style="font-size:14px;font-weight:700;color:var(--yellow)">NT$~134,679</span>
          </div>
        </div>
      </div>
    </div><!-- /left -->

    <!-- RIGHT COL -->
    <div>
      <!-- POSITION SNAPSHOT -->
      <div class="sep">📋 倉位快照</div>
      <div class="card" style="padding:12px">
        <table class="pt" id="pos-snapshot">
          <thead><tr>
            <th>倉位</th><th>DTE</th><th>Δ</th><th>Θ/日</th><th>獲利%</th><th>狀態</th>
          </tr></thead>
          <tbody id="pos-snapshot-body"></tbody>
        </table>
      </div>

      <!-- KEY METRICS -->
      <div class="sep">📊 帳戶關鍵指標</div>
      <div class="grid3">
        <div class="sum-card"><div class="sc-label">維持率</div><div class="sc-val yellow">174.9%</div><div class="sc-sub">目標 >180%</div></div>
        <div class="sum-card"><div class="sc-label">淨 Delta</div><div class="sc-val">80.5</div><div class="sc-sub">上限 200</div></div>
        <div class="sum-card"><div class="sc-label">槓桿</div><div class="sc-val yellow">2.45×</div><div class="sc-sub">目標 ≤2×</div></div>
      </div>
    </div><!-- /right -->

  </div><!-- /grid2 -->

  <!-- ANI MORNING BRIEFING -->
  <div class="sep">🤖 Ani 今日晨報</div>
  <div class="briefing-box">
    <div class="briefing-title">🤖 Ani · 今日策略晨報</div>
    <div id="ani-briefing">
      <div class="loading"><span></span><span></span><span></span></div>
    </div>
  </div>

</div><!-- /wrap -->

<script>
// ── POSITION DATA ──
const POSITIONS = [
  {sym:'TSLA',strat:'CC', strike:460,qty:4, dte:36,delta:0.179,theta:85.6,pnlPct:52.8,origPrem:12.19,curPrem:5.75,underlying:383.97},
  {sym:'VTI', strat:'CC', strike:370,qty:1, dte:36,delta:0.376,theta:9.9, pnlPct:50.9,origPrem:8.35, curPrem:4.10,underlying:359.92},
  {sym:'NVDA',strat:'CC', strike:235,qty:1, dte:36,delta:0.175,theta:9.0, pnlPct:20.0,origPrem:3.05, curPrem:2.44,underlying:202.35},
  {sym:'TSLA',strat:'CSP',strike:370,qty:1, dte:36,delta:0.333,theta:28.8,pnlPct:-40.3,origPrem:10.41,curPrem:14.60,underlying:383.97},
  {sym:'NVDA',strat:'CSP',strike:215,qty:1, dte:36,delta:0.605,theta:12.5,pnlPct:-38.5,origPrem:11.19,curPrem:15.50,underlying:202.35},
  {sym:'VTI', strat:'CSP',strike:340,qty:1, dte:36,delta:0.167,theta:8.4, pnlPct:16.3,origPrem:3.19, curPrem:2.67,underlying:359.92},
  {sym:'IWM', strat:'BPS',strike:272,qty:3, dte:36,delta:0.126,theta:6.9, pnlPct:-11.6,origPrem:1.89,curPrem:2.11,underlying:283.80},
  {sym:'IWM', strat:'BPS',strike:268,qty:3, dte:36,delta:0.111,theta:11.7,pnlPct:11.1,origPrem:1.72, curPrem:1.53,underlying:283.80},
  {sym:'QQQ', strat:'BPS',strike:680,qty:1, dte:36,delta:0.136,theta:4.5, pnlPct:-54.6,origPrem:3.79,curPrem:5.86,underlying:696.87},
  {sym:'SPX', strat:'BOX',strike:0,  qty:1, dte:189,delta:0,   theta:0,   pnlPct:0,origPrem:0,curPrem:0,underlying:0},
];

function getSignal(p) {
  if(p.strat==='BOX') return {icon:'📦',text:'到期管理',color:'var(--yellow)'};
  const isCC=p.strat==='CC', isCSP=p.strat==='CSP';
  const otm = isCC ? ((p.strike-p.underlying)/p.underlying*100) : isCSP ? ((p.underlying-p.strike)/p.underlying*100) : 999;
  if(p.dte<=7) return {icon:'🔴',text:'DTE危急',color:'var(--red)'};
  if(otm<0) return {icon:'🔴',text:'價內',color:'var(--red)'};
  if((isCC&&p.delta>=0.30)||(isCSP&&p.delta>=0.50)) return {icon:'🔴',text:'Delta超限',color:'var(--red)'};
  if(p.pnlPct>=75) return {icon:'⚠️',text:'獲利>75%',color:'var(--yellow)'};
  if(p.pnlPct>=50) return {icon:'⚠️',text:'獲利>50%',color:'var(--yellow)'};
  if(p.pnlPct<=-50) return {icon:'⚠️',text:'虧損>50%',color:'var(--red)'};
  if(p.dte<=21) return {icon:'⚠️',text:'DTE≤21',color:'var(--yellow)'};
  return {icon:'✅',text:'健康',color:'var(--green)'};
}

function renderPosSnapshot() {
  const badgeMap = {CC:'b-cc',CSP:'b-csp',BPS:'b-bps',BOX:'b-box'};
  document.getElementById('pos-snapshot-body').innerHTML = POSITIONS.map(p => {
    const sig = getSignal(p);
    const pnlColor = p.pnlPct>0?'var(--green)':p.pnlPct<0?'var(--red)':'var(--muted)';
    const thetaDisplay = p.theta > 0 ? `+$${p.theta.toFixed(1)}` : '—';
    return `<tr>
      <td>
        <span class="badge ${badgeMap[p.strat]}">${p.strat}</span>
        <strong style="margin-left:5px">${p.sym}</strong>
        <span style="font-size:10px;color:var(--muted);margin-left:3px">${p.strat==='BOX'?'Box':p.strat==='BPS'?p.strike+'/'+(p.strike-15):'$'+p.strike} ×${p.qty}</span>
      </td>
      <td style="color:${p.dte<=21?'var(--yellow)':'var(--text)'}">${p.dte}d</td>
      <td style="color:${Math.abs(p.delta)>=0.3?'var(--yellow)':'var(--text)'}">${Math.abs(p.delta).toFixed(3)}</td>
      <td style="color:var(--green)">${thetaDisplay}</td>
      <td style="color:${pnlColor};font-weight:600">${p.pnlPct>0?'+':''}${p.pnlPct.toFixed(1)}%</td>
      <td style="color:${sig.color};font-size:11px">${sig.icon} ${sig.text}</td>
    </tr>`;
  }).join('');
}

// ── GENERATE REPORT (fetch IB + AI) ──
async function generateReport() {
  const btn = document.getElementById('gen-btn');
  btn.disabled = true; btn.textContent = '生成中...';

  // Try to fetch IB data
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        system:'Call IBKR get_account_summary. Return ONLY JSON: {"nlv":number,"excess_liquidity":number,"maintenance_margin":number,"leverage":number}',
        messages:[{role:'user',content:'Fetch account summary now. Return only JSON.'}],
        mcp_servers:[{type:'url',url:'https://api.ibkr.com/v1/api/mcp',name:'ibkr'}]
      })
    });
    const data = await res.json();
    let txt = data.content.filter(b=>b.type==='text').map(b=>b.text).join('');
    txt = txt.replace(/```json\n?|```\n?/g,'').trim();
    const parsed = JSON.parse(txt);
    updateSummaryStrip(parsed);
  } catch(e) { /* use existing data */ }

  await generateAniBriefing();

  document.getElementById('last-gen').textContent = '生成於 ' + new Date().toLocaleTimeString('zh-TW',{hour:'2-digit',minute:'2-digit'});
  btn.disabled = false; btn.textContent = '🔄 生成今日日報';
}

function updateSummaryStrip(d) {
  document.getElementById('r-nlv').textContent = '$' + Math.round(d.nlv).toLocaleString();
  document.getElementById('r-nlv-sub').textContent = '≈ NT$' + Math.round(d.nlv*31.68/10000) + '萬';
  const elPct = (d.excess_liquidity/d.nlv*100);
  const elEl = document.getElementById('r-el');
  elEl.textContent = '$' + Math.round(d.excess_liquidity).toLocaleString();
  elEl.className = 'sc-val ' + (elPct<10?'red':elPct<20?'yellow':'green');
  document.getElementById('r-el-sub').textContent = elPct.toFixed(1) + '% · ' + (elPct<20?'⚠️ 僅BPS':'✅ 健康');
}

async function generateAniBriefing() {
  const el = document.getElementById('ani-briefing');
  el.innerHTML = '<div class="loading"><span></span><span></span><span></span></div>';

  const urgentPositions = POSITIONS.filter(p => {
    const sig = getSignal(p);
    return sig.text.includes('超限') || sig.text.includes('價內') || sig.text.includes('危急');
  }).map(p => `${p.sym} ${p.strat} $${p.strike}`).join(', ');

  const watchPositions = POSITIONS.filter(p => {
    const sig = getSignal(p);
    return sig.text.includes('50%') || sig.text.includes('75%') || sig.text.includes('虧損');
  }).map(p => `${p.sym} ${p.strat} $${p.strike}（${p.pnlPct.toFixed(0)}%）`).join(', ');

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        system:`你是 Ani，Allen 的選擇權策略顧問。每日晨報格式：①市場環境（VIX/趨勢）②倉位警示（最重要的2-3個）③今日建議行動（具體、可執行）④TSLA進度提醒。語氣直接，數字優先，中英混用，總長不超過250字。`,
        messages:[{role:'user',content:`今日晨報 2026/6/11（四）。市場：S&P500 -1.62%，NASDAQ -1.98%，VIX 22.22（+11.8%），TSLA -3.8%（$383.97），NVDA -3.73%（$202.35）。帳戶：NLV $251,749，EL $107,835（42.8%），維持率 174.9%，淨Delta 80.5。🔴緊急：${urgentPositions}。⚠️關注：${watchPositions}。Box 189天到期，每月利息NT$5,322。本月Theta達成率23.7%（目標NT$10萬）。TSLA目標$500進度76.8%。請生成今日晨報。`}]
      })
    });
    const data = await res.json();
    const text = data.content.filter(b=>b.type==='text').map(b=>b.text).join('');
    el.innerHTML = text.replace(/\n/g,'<br>').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>');
  } catch(e) {
    el.textContent = '⚠️ 晨報生成失敗，請確認 API 連線。';
  }
}

// INIT
renderPosSnapshot();
// Auto-generate on load
generateAniBriefing();

// ════════════════════════════════════════════════
// HUB SYNC RECEIVER
// ════════════════════════════════════════════════
function loadSync() {
  try {
    const raw = localStorage.getItem('hub_sync_data');
    if (!raw) return false;
    const d = JSON.parse(raw);

    // Update summary strip with live account data
    if (d.nlv) {
      updateSummaryStrip({
        nlv: d.nlv,
        excess_liquidity: d.excess_liquidity,
        maintenance_margin: d.maintenance_margin,
        leverage: d.leverage,
      });
    }

    // Update POSITIONS array with live data from hub
    if (d.positions && d.positions.length) {
      // Merge hub positions into local POSITIONS (match by sym+strat)
      d.positions.forEach(hp => {
        const local = POSITIONS.find(p => p.sym === hp.sym && p.strat === hp.strat);
        if (local) {
          if (hp.underlying) local.underlying = hp.underlying;
          if (hp.curPrem !== undefined) local.curPrem = hp.curPrem;
          if (hp.pnlPct !== undefined) local.pnlPct = hp.pnlPct;
          if (hp.dte !== undefined) local.dte = hp.dte;
          if (hp.delta !== undefined) local.delta = hp.delta;
        }
      });
      renderPosSnapshot();
    }

    // Sync badge
    const badge = document.getElementById('sync-badge');
    if (badge) {
      const age = Math.round((Date.now() - d.ts) / 1000);
      badge.textContent = (d.isLive ? '✅ Hub 即時' : '📋 Hub 快取')
        + ' · ' + (age < 60 ? age + '秒前' : Math.round(age/60) + '分前');
      badge.style.color = d.isLive ? 'var(--green)' : 'var(--yellow)';
    }
    return true;
  } catch(e) { console.warn('loadSync error:', e); return false; }
}

window.addEventListener('storage', e => {
  if (e.key === 'hub_sync_data') loadSync();
});

loadSync();

</script>
<!-- Code injected by live-server -->
<script>
	// <![CDATA[  <-- For SVG support
	if ('WebSocket' in window) {
		(function () {
			function refreshCSS() {
				var sheets = [].slice.call(document.getElementsByTagName("link"));
				var head = document.getElementsByTagName("head")[0];
				for (var i = 0; i < sheets.length; ++i) {
					var elem = sheets[i];
					var parent = elem.parentElement || head;
					parent.removeChild(elem);
					var rel = elem.rel;
					if (elem.href && typeof rel != "string" || rel.length == 0 || rel.toLowerCase() == "stylesheet") {
						var url = elem.href.replace(/(&|\?)_cacheOverride=\d+/, '');
						elem.href = url + (url.indexOf('?') >= 0 ? '&' : '?') + '_cacheOverride=' + (new Date().valueOf());
					}
					parent.appendChild(elem);
				}
			}
			var protocol = window.location.protocol === 'http:' ? 'ws://' : 'wss://';
			var address = protocol + window.location.host + window.location.pathname + '/ws';
			var socket = new WebSocket(address);
			socket.onmessage = function (msg) {
				if (msg.data == 'reload') window.location.reload();
				else if (msg.data == 'refreshcss') refreshCSS();
			};
			if (sessionStorage && !sessionStorage.getItem('IsThisFirstTime_Log_From_LiveServer')) {
				console.log('Live reload enabled.');
				sessionStorage.setItem('IsThisFirstTime_Log_From_LiveServer', true);
			}
		})();
	}
	else {
		console.error('Upgrade your browser. This Browser is NOT supported WebSocket for Live-Reloading.');
	}
	// ]]>
</script>
</body>
</html>
